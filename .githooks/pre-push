#!/usr/bin/env bash
# Garage Saathi pre-deploy gate. Runs the deterministic g-saathi smoke/regression
# suite before a push that updates main (the GitHub Pages deploy branch). Other
# branches push without the gate. Bypass once with: git push --no-verify.
#
# Enabled via: git config core.hooksPath .githooks  (run once per clone).
set -uo pipefail

# pre-push receives "<localref> <localsha> <remoteref> <remotesha>" lines on stdin.
push_main=0
while read -r _localref _localsha remoteref _remotesha; do
  case "$remoteref" in refs/heads/main) push_main=1 ;; esac
done
[ "$push_main" -eq 1 ] || exit 0

DIR="$(git rev-parse --show-toplevel)"
GATE="$DIR/scripts/predeploy-gate.sh"
[ -x "$GATE" ] || { echo "⚠️  pre-push: $GATE missing/not executable — skipping gate."; exit 0; }
exec "$GATE"
